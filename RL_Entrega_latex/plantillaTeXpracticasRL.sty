% ========== Estilos de títulos ==========
\titleformat{\section}
{\Large\bfseries\color{UMUblue}}{\thesection.}{.5em}{}
\titlespacing{\section}
    {0pt}          % Sangría izquierda
    {0pt}          % Espacio antes del título
    {0pt}          % Espacio después del título
\titleformat{\subsection}
{\large\bfseries\color{UMUblue}}{\thesubsection.}{.5em}{}
\titlespacing{\subsection}
    {0pt}          % Sangría izquierda
    {0pt}          % Espacio antes del título
    {0pt}          % Espacio después del título
\titleformat{\subsubsection}
{\normalsize\bfseries\color{UMUblue}}{\thesubsubsection.}{.5em}{}
\titlespacing{\subsubsection}
    {0pt}          % Sangría izquierda
    {0pt}          % Espacio antes del título
    {0pt}          % Espacio después del título

