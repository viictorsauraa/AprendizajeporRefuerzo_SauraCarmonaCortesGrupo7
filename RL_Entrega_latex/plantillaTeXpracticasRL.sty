% Ejemplos

% 1. Crear el entorno "example"
\newenvironment{example}{}{} % Entorno vacío básico

\tcolorboxenvironment{example}{
  title={\faExclamationCircle\quad Ejemplo},
  colback=white,
  colframe=UMUblue!80,
  arc=3pt,
  boxsep=0pt,
  left=2pt,
  right=2pt,
  top=2pt,
  bottom=2pt
}


